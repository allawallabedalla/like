{
  "name": "like",
  "version": "2.5.0",
  "description": "Like — Künstler-Nachbarschaften (Booking-/Entdeckungs-Tool)",
  "author": "Nicolas Reis",
  "license": "AGPL-3.0-only",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "check": "node scripts/check-config.mjs && node scripts/smoke.mjs",
    "test:e2e": "playwright test",
    "test:ci": "playwright test tests/api.spec.js tests/pages.spec.js tests/pwa.spec.js tests/lock.spec.js tests/responsive.spec.js tests/interactions.spec.js",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:e2e:report": "playwright show-report",
    "dist": "electron-builder --publish never",
    "dist:mac": "electron-builder --mac --publish never",
    "dist:win": "electron-builder --win --publish never"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "electron": "^37.10.3",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "de.nicolasreis.like",
    "productName": "Like",
    "asar": false,
    "afterSign": "scripts/afterSign.js",
    "files": [
      "main.js",
      "server.mjs",
      "lib/**/*",
      "public/**/*",
      "packs/**/*",
      ".lastfm-key",
      ".tmdb-key",
      ".tastedive-key",
      ".pushover",
      "!.songkick-key",
      "!.setlistfm-key",
      "!.bandsintown-appid",
      "!cache/**",
      "!graph*.json",
      "!stats*.json",
      "!digest*.json",
      "!.claude/**",
      "!.git/**",
      "!docs/**",
      "!dist/**"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "Like-${version}-setup.exe",
      "shortcutName": "Like"
    },
    "portable": {
      "artifactName": "Like-${version}-portable.exe"
    },
    "dmg": {
      "artifactName": "Like-${version}-${arch}.dmg"
    }
  },
  "allowScripts": {
    "electron@37.10.3": true,
    "electron-winstaller@5.4.0": true
  }
}
