{
  "name": "like",
  "version": "1.3.0",
  "description": "Like Desktop",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --publish never",
    "dist:mac": "electron-builder --mac --publish never",
    "dist:win": "electron-builder --win --publish never"
  },
  "devDependencies": {
    "electron": "^37.10.3",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "de.nicolasreis.like",
    "productName": "Like",
    "asar": false,
    "afterSign": "scripts/afterSign.js",
    "files": [
      "main.js",
      "server.mjs",
      "lib/**/*",
      "public/**/*",
      ".lastfm-key",
      "!.songkick-key",
      "!.bandsintown-appid",
      "!cache/**",
      "!graph.json",
      "!.claude/**",
      "!.git/**",
      "!docs/**",
      "!dist/**"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": ["universal"]
        }
      ]
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "portable": {
      "artifactName": "Like-${version}-portable.exe"
    },
    "dmg": {
      "artifactName": "Like-${version}-${arch}.dmg"
    }
  },
  "allowScripts": {
    "electron@37.10.3": true,
    "electron-winstaller@5.4.0": true
  }
}
